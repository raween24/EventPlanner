{
  "name": "@microsoft/agents-a365-tooling-extensions-langchain",
  "version": "0.1.0-preview.64",
  "description": "Agent 365 Tooling SDK for LangChain AI agents built with TypeScript/Node.js",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "keywords": [
    "ai",
    "agents",
    "azure",
    "typescript",
    "langchain"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/Agent365-nodejs.git",
    "directory": "packages/agents-a365-tooling-extensions-langchain"
  },
  "dependencies": {
    "@langchain/mcp-adapters": "^1.0.0",
    "@microsoft/agents-a365-runtime": "0.1.0-preview.64",
    "@microsoft/agents-a365-tooling": "0.1.0-preview.64",
    "@microsoft/agents-hosting": "^1.1.0-alpha.85",
    "langchain": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build:cjs": "npx tsc --project tsconfig.cjs.json",
    "build:esm": "npx tsc --project tsconfig.esm.json",
    "build": "npm run build:cjs && npm run build:esm",
    "build:watch": "npx tsc --watch",
    "clean": "npx rimraf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "ci": "npm ci",
    "pack": "node ../../copyFiles.js . && pnpm pack --pack-destination=../"
  }
}